{
  "name": "docsearch-root",
  "version": "1.0.0",
  "description": "DocSearch workspace - Intelligent Document Search Engine",
  "private": true,
  "scripts": {
    "setup": "npm install && npm run install:all",
    "install:all": "npm install --prefix server && npm install --prefix client --legacy-peer-deps",
    "dev": "concurrently --kill-others-on-fail \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "npm run dev --prefix server",
    "client:dev": "npm run dev --prefix client",
    "server:start": "npm start --prefix server",
    "client:build": "npm run build --prefix client",
    "start": "npm run server:start",
    "build": "npm run client:build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
